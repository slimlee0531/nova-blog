# ============================================
# NovaBlog .gitignore
# ============================================

# --------------------------------------------
# Java / Spring Boot
# --------------------------------------------
**/target/
*.class
*.jar
*.war
*.ear
*.log
*.db
hs_err_pid*
replay_pid*

# 排除SQL文件，但保留迁移脚本
!**/db/migration/*.sql

# --------------------------------------------
# Maven
# --------------------------------------------
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# --------------------------------------------
# IDE - IntelliJ IDEA
# --------------------------------------------
.idea/
*.iml
*.iws
*.ipr
out/

# --------------------------------------------
# IDE - Eclipse
# --------------------------------------------
.project
.classpath
.settings/
bin/

# --------------------------------------------
# IDE - VS Code
# --------------------------------------------
.vscode/
*.code-workspace

# --------------------------------------------
# Frontend - Node.js
# --------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --------------------------------------------
# Frontend - Build
# --------------------------------------------
dist/
dist-ssr/
*.local

# --------------------------------------------
# Frontend - Vue
# --------------------------------------------
*.vue.ts

# --------------------------------------------
# 系统文件
# --------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --------------------------------------------
# 环境变量和配置
# --------------------------------------------
.env
.env.local
.env.*.local
application-local.properties
application-dev.properties
application.yml
application-*.yml

# --------------------------------------------
# 日志文件
# --------------------------------------------
*.log
logs/
logs.*

# --------------------------------------------
# 临时文件
# --------------------------------------------
*.tmp
*.temp
*.swp
*.swo
*~
.cache/
.cache

# --------------------------------------------
# 文档文件夹（不需要提交）
# --------------------------------------------
docs/

# --------------------------------------------
# 测试报告
# --------------------------------------------
test-results/
coverage/
.nyc_output/

# --------------------------------------------
# Docker
# --------------------------------------------
docker-compose.override.yml

# --------------------------------------------
# 项目特定
# --------------------------------------------
blog-backend/blog-backend.log
blog-backend/*.log
blog-frontend/dist/
